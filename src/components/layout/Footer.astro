---
const currentYear = new Date().getFullYear();
const whatsappUrl = 'https://wa.me/50258330848';

const productLinks = [
  { href: '/productos/herramientas-manuales', label: 'Herramientas Manuales' },
  { href: '/productos/herramientas-electricas', label: 'Herramientas Eléctricas' },
  { href: '/productos/materiales-construccion', label: 'Materiales de Construcción' },
  { href: '/productos/plomeria-pvc', label: 'Plomería y PVC' },
  { href: '/productos/seguridad-industrial', label: 'Seguridad Industrial' },
  { href: '/productos/pintura', label: 'Pintura y Accesorios' },
];

const infoLinks = [
  { href: '/nosotros', label: 'Sobre Nosotros' },
  { href: '/marcas', label: 'Nuestras Marcas' },
  { href: '/contacto', label: 'Contacto' },
];
---

<footer class="bg-gray-900 text-white">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <!-- Logo -->
        <a
          href="/"
          class="inline-flex items-center no-underline mb-4"
          aria-label="Dismafer - Inicio"
        >
          <span class="text-2xl font-bold text-white font-heading tracking-tight">
            Dism<svg
              class="inline-block w-6 h-7 -mt-1"
              viewBox="0 0 24 28"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M12 3L2 11V25H9V17H15V25H22V11L12 3Z"
                fill="#F66C26"
                stroke="#F66C26"
                stroke-width="1"
                stroke-linejoin="round"></path>
              <path d="M12 3L2 11" stroke="#F66C26" stroke-width="2" stroke-linecap="round"></path>
              <path d="M12 3L22 11" stroke="#F66C26" stroke-width="2" stroke-linecap="round"></path>
            </svg>fer
          </span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mt-3">
          Más de 20 años siendo la ferretería de confianza en Zona 9, Ciudad de Guatemala.
          Herramientas, materiales y soluciones para tu proyecto.
        </p>
        <!-- Social -->
        <div class="flex items-center gap-3 mt-5">
          <a
            href="https://www.facebook.com/dismaferz9/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-blue-600 hover:bg-blue-700 rounded-lg flex items-center justify-center transition-colors no-underline"
            aria-label="Facebook de Dismafer"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-green-500 hover:bg-green-600 rounded-lg flex items-center justify-center transition-colors no-underline"
            aria-label="WhatsApp de Dismafer"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Products column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Productos</h3>
        <ul class="space-y-2">
          {
            productLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-400 hover:text-accent text-sm transition-colors no-underline"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Info column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Información</h3>
        <ul class="space-y-2 mb-6">
          {
            infoLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-400 hover:text-accent text-sm transition-colors no-underline"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Horarios -->
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-3">Horarios</h3>
        <ul class="space-y-1.5">
          <li class="flex justify-between text-sm">
            <span class="text-gray-400">Lun — Vie</span>
            <span class="text-white font-medium">7:00 — 17:30</span>
          </li>
          <li class="flex justify-between text-sm">
            <span class="text-gray-400">Sábado</span>
            <span class="text-white font-medium">7:00 — 14:00</span>
          </li>
          <li class="flex justify-between text-sm">
            <span class="text-gray-400">Domingo</span>
            <span class="text-gray-500 italic">Cerrado</span>
          </li>
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contacto</h3>
        <ul class="space-y-3">
          <!-- Address -->
          <li class="flex items-start gap-3">
            <svg
              class="w-4 h-4 text-accent mt-0.5 flex-shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <address class="text-gray-400 text-sm not-italic leading-relaxed">
              2ª Calle 2-77, Zona 9<br />
              Ciudad de Guatemala
            </address>
          </li>
          <!-- Phone -->
          <li class="flex items-center gap-3">
            <svg
              class="w-4 h-4 text-accent flex-shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <a
              href="tel:+50222390468"
              class="text-gray-400 hover:text-white text-sm transition-colors no-underline"
            >
              (502) 2339-0468
            </a>
          </li>
          <!-- WhatsApp -->
          <li class="flex items-center gap-3">
            <svg
              class="w-4 h-4 text-green-400 flex-shrink-0"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-400 hover:text-green-400 text-sm transition-colors no-underline"
            >
              +502 5833-0848
            </a>
          </li>
          <!-- Email -->
          <li class="flex items-center gap-3">
            <svg
              class="w-4 h-4 text-accent flex-shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href="mailto:jvargas@dismafer.shop"
              class="text-gray-400 hover:text-white text-sm transition-colors no-underline"
            >
              jvargas@dismafer.shop
            </a>
          </li>
        </ul>

        <!-- WhatsApp CTA -->
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-5 bg-green-500 hover:bg-green-600 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors no-underline"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Contactar ahora
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2"
    >
      <p class="text-gray-500 text-xs">
        &copy; {currentYear} Ferretería Dismafer. Todos los derechos reservados.
      </p>
      <p class="text-gray-600 text-xs">
        2ª Calle 2-77, Zona 9, Ciudad de Guatemala &bull; <a
          href="tel:+50222390468"
          class="hover:text-gray-400 transition-colors no-underline">(502) 2339-0468</a
        >
      </p>
    </div>
  </div>
</footer>
