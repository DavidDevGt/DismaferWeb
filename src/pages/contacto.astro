---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
---

<PageLayout
  title="Contacto — Ferretería Dismafer Guatemala"
  description="Contáctanos por WhatsApp, teléfono o visítanos en 2ª Calle 2-73, Zona 9, Guatemala. Lun-Vie 8:00-17:00 · Sáb 8:00-14:00."
>
  <div class="bg-primary text-white py-12">
    <Container>
      <nav class="text-sm text-white/60 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white no-underline">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">Contacto</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-bold">Contáctanos</h1>
      <p class="text-white/80 mt-2">Estamos para ayudarte. Respuesta rápida por WhatsApp.</p>
    </Container>
  </div>

  <div class="py-16 bg-slate-50">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Opciones de contacto -->
        <div class="space-y-6">
          <h2 class="text-2xl font-heading font-bold text-primary">Canales de atención</h2>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/50258330848?text=Hola%2C%20me%20interesa%20informaci%C3%B3n%20sobre%20sus%20productos"
            target="_blank"
            class="flex items-center gap-5 bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md hover:border-green-200 transition-all no-underline group"
          >
            <div
              class="w-14 h-14 rounded-2xl bg-green-500 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform"
            >
              <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path></svg
              >
            </div>
            <div>
              <p class="font-heading font-bold text-primary text-lg">WhatsApp</p>
              <p class="text-green-600 font-semibold">+502 5833-0848</p>
              <p class="text-neutral text-sm mt-0.5">Canal preferido · Respuesta en minutos</p>
            </div>
          </a>

          <!-- Teléfono -->
          <a
            href="tel:+50223390468"
            class="flex items-center gap-5 bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md hover:border-primary/20 transition-all no-underline group"
          >
            <div
              class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:scale-110 transition-all"
            >
              <svg
                class="w-7 h-7 text-primary group-hover:text-white transition-colors"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-primary text-lg">Teléfono</p>
              <p class="text-accent font-semibold">(502) 2339-0468</p>
              <p class="text-neutral text-sm mt-0.5">Lun-Vie 8:00-17:00 · Sáb 8:00-14:00</p>
            </div>
          </a>

          <!-- Dirección -->
          <a
            href="https://maps.google.com/?q=Ferreteria+Dismafer+2a+Calle+2-73+Zona+9+Guatemala"
            target="_blank"
            class="flex items-center gap-5 bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md hover:border-primary/20 transition-all no-underline group"
          >
            <div
              class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:scale-110 transition-all"
            >
              <svg
                class="w-7 h-7 text-primary group-hover:text-white transition-colors"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-primary text-lg">Visítanos</p>
              <p class="text-neutral font-medium">2ª Calle 2-73, Zona 9</p>
              <p class="text-neutral text-sm">Ciudad de Guatemala · Ver en Maps →</p>
            </div>
          </a>

          </div>

        <!-- Horarios + mapa -->
        <div class="space-y-6">
          <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
            <h2 class="text-xl font-heading font-bold text-primary mb-5">Horarios de atención</h2>
            <div class="space-y-3">
              {
                [
                  { day: 'Lunes', hours: '8:00 – 17:00' },
                  { day: 'Martes', hours: '8:00 – 17:00' },
                  { day: 'Miércoles', hours: '8:00 – 17:00' },
                  { day: 'Jueves', hours: '8:00 – 17:00' },
                  { day: 'Viernes', hours: '8:00 – 17:00' },
                  { day: 'Sábado', hours: '8:00 – 14:00' },
                  { day: 'Domingo', hours: 'Cerrado' },
                ].map(({ day, hours }) => (
                  <div class="flex justify-between items-center py-2 border-b border-gray-50 last:border-0">
                    <span class="font-medium text-primary text-sm">{day}</span>
                    <span
                      class={`text-sm font-semibold ${hours === 'Cerrado' ? 'text-neutral' : 'text-accent'}`}
                    >
                      {hours}
                    </span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Mapa placeholder -->
          <div
            class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm h-64 flex items-center justify-center"
          >
            <div class="text-center p-6">
              <svg
                class="w-10 h-10 text-primary/30 mx-auto mb-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
                ></path>
              </svg>
              <p class="font-semibold text-primary">2ª Calle 2-73, Zona 9</p>
              <p class="text-neutral text-sm">Ciudad de Guatemala</p>
              <a
                href="https://maps.google.com/?q=Ferreteria+Dismafer+2a+Calle+2-73+Zona+9+Guatemala"
                target="_blank"
                class="mt-3 inline-block text-accent font-semibold text-sm hover:underline"
              >
                Abrir en Google Maps →
              </a>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </div>
</PageLayout>
