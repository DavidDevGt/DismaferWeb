---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
---

<PageLayout
  title="Página no encontrada — Ferretería Dismafer"
  description="La página que buscas no existe."
  noindex={true}
>
  <div class="min-h-[60vh] flex items-center justify-center bg-slate-50">
    <Container>
      <div class="text-center py-20">
        <p class="text-8xl font-heading font-bold text-accent mb-4">404</p>
        <h1 class="text-3xl font-heading font-bold text-primary mb-4">Página no encontrada</h1>
        <p class="text-neutral mb-8 max-w-md mx-auto">
          La página que buscas no existe o fue movida. ¿Necesitas ayuda para encontrar un producto?
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-blue-900 text-white font-bold px-8 py-4 rounded-xl transition-colors no-underline"
          >
            Ir al inicio
          </a>
          <a
            href="https://wa.me/50258330848"
            target="_blank"
            class="inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-xl transition-colors no-underline"
          >
            Preguntar por WhatsApp
          </a>
        </div>
      </div>
    </Container>
  </div>
</PageLayout>
