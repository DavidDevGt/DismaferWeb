---
import type { GetStaticPaths } from 'astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { categories, getCategoryBySlug, getProductsByCategory } from '../../data/index';
import Container from '../../components/ui/Container.astro';
import Badge from '../../components/ui/Badge.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return categories.map((cat) => ({
    params: { categoria: cat.slug },
    props: { category: cat },
  }));
};

const { categoria } = Astro.params;
const category = getCategoryBySlug(categoria!);
const products = getProductsByCategory(categoria!);

if (!category) return Astro.redirect('/productos');
---

<PageLayout
  title={`${category.name} — Ferretería Dismafer Guatemala`}
  description={`${category.description} Disponibles en Ferretería Dismafer, Zona 9, Ciudad de Guatemala.`}
>
  <!-- Header -->
  <div class="bg-primary text-white py-12">
    <Container>
      <nav class="text-sm text-white/60 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white no-underline">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/productos" class="hover:text-white no-underline">Productos</a>
        <span class="mx-2">/</span>
        <span class="text-white">{category.name}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-bold">{category.name}</h1>
      <p class="text-white/80 mt-2 max-w-2xl">{category.description}</p>
    </Container>
  </div>

  <!-- Products -->
  <div class="py-12 bg-slate-50">
    <Container>
      {
        products.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map((product) => (
              <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow flex flex-col">
                <div class="w-full h-40 bg-slate-100 rounded-xl mb-4 flex items-center justify-center">
                  <svg
                    class="w-12 h-12 text-slate-300"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1"
                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <div class="flex-1 flex flex-col">
                  {product.featured && (
                    <Badge variant="accent" class="self-start mb-2">
                      Destacado
                    </Badge>
                  )}
                  <h3 class="font-heading font-bold text-primary text-lg leading-snug mb-2">
                    {product.name}
                  </h3>
                  <p class="text-neutral text-sm leading-relaxed flex-1">
                    {product.shortDescription}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-1">
                    {product.tags.slice(0, 3).map((tag: string) => (
                      <span class="text-xs bg-slate-100 text-neutral px-2 py-0.5 rounded-full">
                        #{tag}
                      </span>
                    ))}
                  </div>
                  <a
                    href={`https://wa.me/50258330848?text=Hola%2C%20me%20interesa%20el%20producto%3A%20${encodeURIComponent(product.name)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-5 flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-semibold text-sm px-4 py-3 rounded-xl transition-colors no-underline"
                  >
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                    </svg>
                    Consultar precio
                  </a>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-20">
            <p class="text-neutral text-lg mb-4">Pronto habrá productos en esta categoría.</p>
            <a href="/contacto" class="text-accent font-semibold hover:underline">
              Consultar disponibilidad →
            </a>
          </div>
        )
      }
    </Container>
  </div>
</PageLayout>
