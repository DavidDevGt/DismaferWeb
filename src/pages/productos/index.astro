---
import PageLayout from '../../layouts/PageLayout.astro';
import { categories } from '../../data/index';
import Container from '../../components/ui/Container.astro';

const iconPaths: Record<string, string> = {
  'herramienta-manual':
    'M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z',
  'herramienta-electrica': 'M13 10V3L4 14h7v7l9-11h-7z',
  'tuberia-pvc':
    'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
  'seguridad-industrial':
    'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  pinturas:
    'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  'materiales-construccion':
    'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
};
---

<PageLayout
  title="Productos — Ferretería Dismafer Guatemala"
  description="Catálogo de productos: herramientas manuales y eléctricas, tubería PVC, seguridad industrial, pinturas y materiales de construcción. Zona 9, Guatemala."
>
  <!-- Page header -->
  <div class="bg-primary text-white py-12">
    <Container>
      <nav class="text-sm text-white/60 mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white no-underline">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-white">Productos</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-bold">Nuestros Productos</h1>
      <p class="text-white/80 mt-2 max-w-2xl">
        Más de 500 productos disponibles. Consulta disponibilidad por WhatsApp.
      </p>
    </Container>
  </div>

  <!-- Categories grid -->
  <div class="py-12 bg-slate-50">
    <Container>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          categories.map((cat) => (
            <a
              href={`/productos/${cat.slug}`}
              class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg border border-gray-100 hover:border-accent/30 transition-all duration-300 no-underline"
            >
              <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center group-hover:bg-accent group-hover:scale-110 transition-all duration-300 mb-5">
                <svg
                  class="w-7 h-7 text-primary group-hover:text-white transition-colors"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d={iconPaths[cat.slug] ?? iconPaths['herramienta-manual']}
                  />
                </svg>
              </div>
              <h2 class="text-xl font-heading font-bold text-primary mb-2 group-hover:text-accent transition-colors">
                {cat.name}
              </h2>
              <p class="text-neutral text-sm leading-relaxed mb-4">{cat.description}</p>
              <div class="flex items-center gap-1 text-accent text-sm font-semibold">
                Ver productos
                <svg
                  class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </div>
            </a>
          ))
        }
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
        <p class="text-lg font-semibold text-primary mb-2">¿No encuentras lo que buscas?</p>
        <p class="text-neutral mb-6">
          Si no lo tenemos en stock, lo conseguimos. Escríbenos con tu requerimiento.
        </p>
        <a
          href="https://wa.me/50258330848?text=Hola%2C%20busco%20el%20siguiente%20producto%3A%20"
          target="_blank"
          class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl transition-all no-underline"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path></svg
          >
          Consultar por WhatsApp
        </a>
      </div>
    </Container>
  </div>
</PageLayout>
